#:kivy 2.3.0

<TabbedPanel>:
    do_default_tab: False
    tab_pos: 'top_mid'
    tab_width: root.width / 3
    tab_height: '60dp'

    canvas.before:
        Color:
            rgb: 0.95, 0.95, 0.95
        Rectangle:
            pos: self.pos
            size: self.size

<TabbedPanelHeader>:
    background_color: (0.2, 0.6, 0.8, 1) if self.state == 'down' else (0.8, 0.8, 0.8, 1)
    background_normal: ''
    background_down: ''
    font_name: 'DefaultFont'
    font_size: '18sp'
    bold: True

<RandomNumberTab>:
    BoxLayout:
        orientation: 'vertical'
        padding: [20, 20]
        spacing: 15

        Label:
            text: '随机数生成器'
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: '50dp'
            font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: None
            height: '60dp'

            Label:
                text: '最小值:'
                size_hint_x: 0.3
                font_size: '18sp'
                font_name: 'DefaultFont'

            TextInput:
                id: min_input
                text: '0'
                size_hint_x: 0.7
                input_filter: 'int'
                font_size: '20sp'
                halign: 'center'
                background_color: (0.95, 0.95, 0.95, 1)
                font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: None
            height: '60dp'

            Label:
                text: '最大值:'
                size_hint_x: 0.3
                font_size: '18sp'
                font_name: 'DefaultFont'

            TextInput:
                id: max_input
                text: '100'
                size_hint_x: 0.7
                input_filter: 'int'
                font_size: '20sp'
                halign: 'center'
                background_color: (0.95, 0.95, 0.95, 1)
                font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: None
            height: '60dp'

            Label:
                text: '生成数量:'
                size_hint_x: 0.3
                font_size: '18sp'
                font_name: 'DefaultFont'

            Spinner:
                id: count_spinner
                text: '1'
                values: ['1', '2', '3', '4', '5', '10', '20', '50', '100']
                size_hint_x: 0.7
                background_color: (0.95, 0.95, 0.95, 1)
                font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: None
            height: '60dp'

            Button:
                text: '生成随机数'
                on_release: root.generate_random()
                size_hint_x: 0.6
                background_color: (0.2, 0.6, 0.8, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_size: '18sp'
                bold: True
                font_name: 'DefaultFont'

            Button:
                text: '重置'
                on_release: root.reset_inputs()
                size_hint_x: 0.4
                background_color: (0.8, 0.5, 0.2, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_size: '18sp'
                font_name: 'DefaultFont'

        Label:
            text: root.result_text
            font_size: '22sp'
            bold: True
            halign: 'center'
            color: (0.1, 0.5, 0.8, 1)
            size_hint_y: None
            height: '50dp'
            font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 5
            size_hint_y: None
            height: '50dp'

            Button:
                text: '复制结果'
                on_release: root.copy_result()
                size_hint_x: 0.5
                background_color: (0.4, 0.7, 0.4, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_size: '16sp'
                font_name: 'DefaultFont'

            Button:
                text: '历史记录'
                on_release: root.show_history_popup()
                size_hint_x: 0.5
                background_color: (0.6, 0.6, 0.6, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_size: '16sp'
                font_name: 'DefaultFont'

<TextRandomTab>:
    BoxLayout:
        orientation: 'vertical'
        padding: [20, 20]
        spacing: 15

        Label:
            text: '文本随机选择'
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: '50dp'
            font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 10
            size_hint_y: None
            height: '40dp'

            Label:
                text: '选项数量:'
                size_hint_x: 0.4
                font_size: '18sp'
                font_name: 'DefaultFont'

            Label:
                text: str(root.options_count)
                font_size: '20sp'
                bold: True
                color: (0.1, 0.5, 0.8, 1)
                size_hint_x: 0.6
                font_name: 'DefaultFont'

        Label:
            text: '输入选项 (每行一个):'
            size_hint_y: None
            height: '30dp'
            font_size: '16sp'
            font_name: 'DefaultFont'

        ScrollView:
            TextInput:
                id: text_input
                hint_text: '输入选项，每行一个...'
                multiline: True
                font_size: '16sp'
                background_color: (0.95, 0.95, 0.95, 1)
                on_text: root.update_options_count()
                font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 5
            size_hint_y: None
            height: '50dp'

            Button:
                text: '加载模板'
                on_release: root.show_template_popup()
                background_color: (0.4, 0.6, 0.8, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_name: 'DefaultFont'

            Button:
                text: '清空'
                on_release: root.clear_text()
                background_color: (0.8, 0.4, 0.4, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_name: 'DefaultFont'

        BoxLayout:
            orientation: 'horizontal'
            spacing: 5
            size_hint_y: None
            height: '40dp'

            CheckBox:
                id: remove_after_select
                size_hint_x: 0.2

            Label:
                text: '选择后移除该选项'
                size_hint_x: 0.8
                font_size: '16sp'
                font_name: 'DefaultFont'

        Button:
            text: '随机选择'
            on_release: root.random_select()
            background_color: (0.2, 0.7, 0.3, 1)
            background_normal: ''
            color: (1, 1, 1, 1)
            font_size: '20sp'
            bold: True
            size_hint_y: None
            height: '60dp'
            font_name: 'DefaultFont'

        Label:
            text: root.result_text
            font_size: '22sp'
            bold: True
            halign: 'center'
            color: (0.1, 0.5, 0.8, 1)
            size_hint_y: None
            height: '50dp'
            font_name: 'DefaultFont'

<SettingsTab>:
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            padding: [20, 20]
            spacing: 20
            size_hint_y: None
            height: 600

            Label:
                text: '设置'
                font_size: '24sp'
                bold: True
                size_hint_y: None
                height: '50dp'
                font_name: 'DefaultFont'

            Button:
                text: '清除历史记录'
                on_release: root.clear_history()
                background_color: (0.8, 0.4, 0.4, 1)
                background_normal: ''
                color: (1, 1, 1, 1)
                font_size: '18sp'
                size_hint_y: None
                height: '50dp'
                font_name: 'DefaultFont'

            BoxLayout:
                orientation: 'vertical'
                spacing: 10
                size_hint_y: None
                height: '150dp'

                Label:
                    text: '关于'
                    font_size: '20sp'
                    halign: 'center'
                    size_hint_y: None
                    height: '40dp'
                    font_name: 'DefaultFont'

                Label:
                    text: '随机工具 v1.0\n\n功能：\n• 随机数生成\n• 文本随机选择\n• 历史记录'
                    halign: 'center'
                    font_size: '16sp'
                    font_name: 'DefaultFont'

            Label:
                text: '© 2024 随机工具\n开发者工具项目'
                font_size: '14sp'
                halign: 'center'
                color: (0.5, 0.5, 0.5, 1)
                size_hint_y: None
                height: '60dp'
                font_name: 'DefaultFont'