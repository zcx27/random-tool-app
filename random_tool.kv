#:kivy 2.3.0

<ThemeLabel>:
    font_name: 'ChineseFont'
    text_size: self.size
    halign: 'center'
    valign: 'middle'

<ThemeButton>:
    font_name: 'ChineseFont'
    background_normal: ''
    background_down: ''

<ThemeTextInput>:
    font_name: 'ChineseFont'
    background_normal: ''
    background_active: ''
